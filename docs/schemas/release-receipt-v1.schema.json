{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchlog.dev/schemas/release-receipt/v1",
  "title": "Patchlog release receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "plan_fingerprint",
    "phase",
    "repository",
    "source_commit",
    "tag",
    "artifacts",
    "verification"
  ],
  "properties": {
    "schema": {
      "const": "https://patchlog.dev/schemas/release-receipt/v1"
    },
    "schema_version": {
      "const": 1
    },
    "plan_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "phase": {
      "const": "finalize"
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "tag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "digest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sha256"],
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_plan_bound_to_tag",
        "required_gate_passed",
        "tag_matches_version",
        "tag_targets_source_commit"
      ],
      "properties": {
        "approved_plan_bound_to_tag": {
          "const": true
        },
        "required_gate_passed": {
          "const": true
        },
        "tag_matches_version": {
          "const": true
        },
        "tag_targets_source_commit": {
          "const": true
        }
      }
    }
  }
}
