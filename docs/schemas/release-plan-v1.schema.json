{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchlog.dev/schemas/release-plan/v1",
  "title": "Patchlog release plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fingerprint",
    "schema_version",
    "phase",
    "head",
    "target_version",
    "tag_requested",
    "push_requested",
    "publish_requested",
    "actions",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "https://patchlog.dev/schemas/release-plan/v1"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "schema_version": {
      "const": 1
    },
    "phase": {
      "enum": ["prepare", "finalize"]
    },
    "head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "protected_branch": {
      "type": "string",
      "minLength": 1
    },
    "release_branch": {
      "type": "string",
      "minLength": 1
    },
    "current_version": {
      "type": "string",
      "minLength": 1
    },
    "target_version": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "minLength": 1
    },
    "tag_requested": {
      "type": "boolean"
    },
    "push_requested": {
      "type": "boolean"
    },
    "publish_requested": {
      "type": "boolean"
    },
    "publish_target": {
      "type": "string",
      "minLength": 1
    },
    "confluence_target": {
      "type": "string",
      "minLength": 1
    },
    "rendered_output_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "mutation_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mode", "before_sha256", "after_sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "integer",
            "minimum": 0
          },
          "before_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "after_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "commit_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "provider",
        "repository",
        "branch",
        "commit",
        "required_checks"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40,64}$"
        },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["context"],
            "properties": {
              "context": {
                "type": "string",
                "minLength": 1
              },
              "integration_id": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "const": "prepare"
          }
        }
      },
      "then": {
        "required": [
          "protected_branch",
          "release_branch",
          "current_version",
          "tag"
        ],
        "properties": {
          "files": {
            "minItems": 1
          },
          "tag_requested": {
            "const": false
          },
          "push_requested": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "const": "finalize"
          }
        }
      },
      "then": {
        "required": ["protected_branch", "tag", "commit_policy"],
        "properties": {
          "files": {
            "maxItems": 0
          },
          "tag_requested": {
            "const": true
          },
          "push_requested": {
            "const": true
          }
        }
      }
    }
  ]
}
